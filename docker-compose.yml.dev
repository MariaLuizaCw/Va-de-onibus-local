version: '3.9'

services:
  db:
    image: supabase/postgres:15.1.0.46-rc0
    container_name: vadeonibus-db
    environment:
      POSTGRES_DB: ${DB_NAME}
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    ports:
      - "${DB_PORT}:5432"
    volumes:
      - ./db_data:/var/lib/postgresql/data

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: vadeonibus-backend
    depends_on:
      - db
    volumes:
      - ./common_settings:/app/common_settings
    environment:
      # Database connection
      DATABASE_HOST: db
      DATABASE_PORT: 5432
      DATABASE_USER: ${DB_USER}
      DATABASE_PASSWORD: ${DB_PASSWORD}
      DATABASE_NAME: ${DB_NAME}
      
     
      # Rio config
      CATCHUP_HOURS: ${CATCHUP_HOURS}
      MAX_SNAP_DISTANCE_METERS: ${MAX_SNAP_DISTANCE_METERS}
      TERMINAL_PASSAGE_DISTANCE_METERS: ${TERMINAL_PASSAGE_DISTANCE_METERS}
      TERMINAL_PROXIMITY_DISTANCE_METERS: ${TERMINAL_PROXIMITY_DISTANCE_METERS}
      PROXIMITY_WINDOW_MINUTES: ${PROXIMITY_WINDOW_MINUTES}
      PROXIMITY_MIN_DURATION_MINUTES: ${PROXIMITY_MIN_DURATION_MINUTES}
      TRIP_MIN_DURATION_MINUTES: ${TRIP_MIN_DURATION_MINUTES}
      RIO_POLLING_WINDOW_MINUTES: ${RIO_POLLING_WINDOW_MINUTES}


      # SSX Integrations - Angra (Bonfim)
      ANGRA_SSX_USERNAME: ${ANGRA_SSX_USERNAME}
      ANGRA_SSX_PASSWORD: ${ANGRA_SSX_PASSWORD}
      ANGRA_SSX_CLIENT_CODE: ${ANGRA_SSX_CLIENT_CODE}
      ANGRA_SSX_TOKEN_REFRESH_MS: ${ANGRA_SSX_TOKEN_REFRESH_MS}

      # SSX Integrations - Barra do Piraí
      BARRAPIRAI_SSX_USERNAME: ${BARRAPIRAI_SSX_USERNAME}
      BARRAPIRAI_SSX_PASSWORD: ${BARRAPIRAI_SSX_PASSWORD}
      BARRAPIRAI_SSX_CLIENT_CODE: ${BARRAPIRAI_SSX_CLIENT_CODE}
      BARRAPIRAI_SSX_TOKEN_REFRESH_MS: ${BARRAPIRAI_SSX_TOKEN_REFRESH_MS}

      # SSX Integrations - Pedro Antônio
      PEDROANTONIO_SSX_USERNAME: ${PEDROANTONIO_SSX_USERNAME}
      PEDROANTONIO_SSX_PASSWORD: ${PEDROANTONIO_SSX_PASSWORD}
      PEDROANTONIO_SSX_CLIENT_CODE: ${PEDROANTONIO_SSX_CLIENT_CODE}
      PEDROANTONIO_SSX_TOKEN_REFRESH_MS: ${PEDROANTONIO_SSX_TOKEN_REFRESH_MS}

      # SSX Integrations - Resendense
      RESENDENSE_SSX_USERNAME: ${RESENDENSE_SSX_USERNAME}
      RESENDENSE_SSX_PASSWORD: ${RESENDENSE_SSX_PASSWORD}
      RESENDENSE_SSX_CLIENT_CODE: ${RESENDENSE_SSX_CLIENT_CODE}
      RESENDENSE_SSX_TOKEN_REFRESH_MS: ${RESENDENSE_SSX_TOKEN_REFRESH_MS}

      # RioIta config
      RIOITA_CITTATI_USERNAME: ${RIOITA_CITTATI_USERNAME}
      RIOITA_CITTATI_PASSWORD: ${RIOITA_CITTATI_PASSWORD}
      RIOITA_TOKEN_REFRESH_MS: ${RIOITA_TOKEN_REFRESH_MS}
      
      # GTFS-RT config
      GTFSRTURL: ${GTFSRTURL}

      # Sentido & Reports
      SENTIDO_BATCH_SIZE: ${SENTIDO_BATCH_SIZE}
      DB_BATCH_SIZE: ${DB_BATCH_SIZE}

      # api
      API_BASE_PATH: ${API_BASE_PATH}
      AUTH_USERNAME: ${AUTH_USERNAME}
      AUTH_PASSWORD: ${AUTH_PASSWORD}
      JWT_SECRET: ${JWT_SECRET}
      JWT_EXPIRES_IN: ${JWT_EXPIRES_IN}

      # Logs 
      JOB_LOG_RETENTION_DAYS: ${JOB_LOG_RETENTION_DAYS}

      # Timezone
      API_TIMEZONE: ${API_TIMEZONE}
      PROXIMITY_EVENT_RETENTION_HOURS: ${PROXIMITY_EVENT_RETENTION_HOURS}
      HISTORICO_VIAGENS_RETENTION_DAYS: ${HISTORICO_VIAGENS_RETENTION_DAYS}
    
    ports:
      - "${BACKEND_PORT}:3001"

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: vadeonibus-frontend
    volumes:
      - ./common_settings:/app/src/lib/common_settings
    environment:
      PUBLIC_BACKEND_URL: ${BACKEND_URL}
      PUBLIC_JOB_LOG_RETENTION_DAYS: ${JOB_LOG_RETENTION_DAYS}
    ports:
      - "5173:5173"

volumes:
  db_data:
